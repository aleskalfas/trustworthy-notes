{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-kit/capabilities/project-management/workstreams.schema.json",
  "title": "Workstreams file shape — project-management capability",
  "description": "JSON Schema for `.pkit/capabilities/project-management/project/workstreams.yaml`. Per project-management:DEC-018, accepts two forms: a mapping `workstreams:` from kebab-case slug to attribute mapping (canonical) or a list of slug strings (shorthand). Slugs match `^[a-z][a-z0-9-]*[a-z0-9]$`, 2–40 chars, no consecutive hyphens.",
  "type": "object",
  "required": ["schema_version", "workstreams"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "description": "Schema version of this file shape (currently 1).",
      "type": "integer",
      "minimum": 1
    },
    "workstreams": {
      "description": "Either a mapping (slug → attributes) or a list (of slugs only).",
      "oneOf": [
        {
          "type": "object",
          "patternProperties": {
            "^[a-z][a-z0-9-]*[a-z0-9]$": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": {
                  "description": "Human-readable name. Defaults to the slug if omitted.",
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64,
                  "pattern": "^[^\\n\\r]+$"
                },
                "description": {
                  "description": "One-line prose, ≤ 200 chars, no newlines.",
                  "type": "string",
                  "maxLength": 200,
                  "pattern": "^[^\\n\\r]*$"
                },
                "status": {
                  "description": "Lifecycle status; defaults to `active`.",
                  "type": "string",
                  "enum": ["active", "deprecated"]
                },
                "deprecated_reason": {
                  "description": "Audit prose explaining the deprecation. Encouraged when status=deprecated.",
                  "type": "string",
                  "maxLength": 200,
                  "pattern": "^[^\\n\\r]*$"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
            "minLength": 2,
            "maxLength": 40
          },
          "uniqueItems": true
        }
      ]
    }
  }
}
