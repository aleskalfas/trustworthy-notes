# Python / uv
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Build artifacts (uv build / hatch build / pip wheel)
build/
dist/

# Build stamp baked at freeze time by scripts/stamp_build.py — generated, never
# committed (a clean checkout falls back to the "dev" stamp; see build.py).
src/trustworthy_notes/_build_stamp.py

# OS junk
.DS_Store

# Personal, per-machine harness settings (team config lives in settings.json)
.claude/settings.local.json

# ── User-local / generated data — never committed (relevant only to the user) ──
# Generated output is per-document, written to a sibling <name>.tnotes/ folder
# (data/Foo.pdf → data/Foo.pdf.tnotes/): ingest/extract/compose/export artifacts
# with verbatim excerpts from local/copyrighted sources. Ignored wherever it lands.
*.tnotes/
data/*/
# The combined book is written beside the source as <stem>.tnotes.md/.pdf
# (and the reading copy <stem>.tnotes.reading.md/.pdf) — same generated, derived
# content as the folder above, so ignore it wherever it lands.
*.tnotes.md
*.tnotes.pdf
*.tnotes.reading.md
*.tnotes.reading.pdf
# Per-page inspection output: annotated scans (tnotes render) and page-text dumps
# (tnotes probe --out) — both derived from the source PDF.
scans/
*.scan.png
pdf-page-*.txt

# Copyrighted source PDFs — keep local, do not publish.
# Remove this line if a given PDF is yours to distribute.
data/*.pdf

# NOTE: committed test fixtures (tests/fixtures/) are project assets, not
# generated data — the patterns above are scoped so they stay tracked.
